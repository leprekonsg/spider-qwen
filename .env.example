# spider-qwen environment configuration
# Copy to .env and fill in. NEVER commit .env.

# --- TinyFish (primary web layer: Search + Fetch) ---
TINYFISH_API_KEY=your_tinyfish_key_here
TINYFISH_SEARCH_BASE_URL=https://api.search.tinyfish.ai
TINYFISH_FETCH_BASE_URL=https://api.fetch.tinyfish.ai
TINYFISH_FETCH_BATCH_SIZE=10
TINYFISH_TIMEOUT_SECONDS=60
TINYFISH_MAX_RETRIES=2
TINYFISH_SEARCH_RPM=30
TINYFISH_FETCH_URLS_PER_MINUTE=150

# --- Qwen / Alibaba Model Studio (WebExtractor fallback + optional MCP search) ---
# Used only by the optional Qwen WebExtractor single-page fallback provider.
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
QWEN_WEB_EXTRACTOR_MODEL=qwen3.7-max
QWEN_ROUTER_MODEL=qwen3.7-max
QWEN_JSON_EXTRACTOR_MODEL=qwen-flash
QWEN_STRUCTURED_EXTRACTION_ENABLED=0
QWEN_ROUTER_FALLBACK_ENABLED=0
QWEN_ROUTER_CONFIDENCE_THRESHOLD=0.65
# T-2.1 page judge gate: reject/flag low-trust pages before the ledger persists
# them (heuristic + offline; set to 1 to enable in the pipeline).
QWEN_PAGE_JUDGE_ENABLED=0
# T-2.2 verification spine: block candidates whose critical claims are not
# grounded in their cited evidence (heuristic + offline; set to 1 to enable).
SPIDER_QWEN_VERIFICATION_ENABLED=0
# T-2.2 seam: Qwen scores (claim, span) entailment inside MiniCheck. The
# deterministic heuristic keeps final authority (score clamped, co-location
# guard re-applied, exceptions fall back). Needs DASHSCOPE_API_KEY.
QWEN_NLI_ENABLED=0
QWEN_NLI_MODEL=qwen-flash
# Conformal emission gate: JSON file of hand-graded verifier examples, e.g.
# {"alpha": 0.1, "examples": [{"verifier_score": 0.9, "prediction_correct": true}]}
# Build with `spider-qwen calibrate template <run_id> --out calibration.json`,
# hand-grade prediction_correct, then validate with `spider-qwen calibrate check`.
# Unset: the gate never blocks and run metrics state that no guarantee exists.
# SPIDER_QWEN_CONFORMAL_CALIBRATION=

# Optional Ed25519 STH signing key for persisted evidence tree heads.
# Generate/store outside git; value is raw 32-byte private key hex.
# SPIDER_QWEN_STH_SIGNING_KEY=

# --- Model role overrides (canonical roles live in governance/policy_config.yaml
#     models: block; uncomment to override a single role for a live demo) ---
# SPIDER_QWEN_MODEL_PLANNER=qwen3.7-max
# SPIDER_QWEN_MODEL_EXTRACTION=qwen3.5-flash
# SPIDER_QWEN_MODEL_EMBEDDINGS=text-embedding-v4
# SPIDER_QWEN_MODEL_OCR=qwen-vl-ocr-2025-11-20

# --- Search provider selection: tinyfish | qwen_mcp | mock ---
SPIDER_QWEN_SEARCH_PROVIDER=tinyfish
# qwen_mcp consumes any MCP stdio server exposing a search tool (needs .[mcp]):
# SPIDER_QWEN_MCP_SEARCH_COMMAND=python -m my_search_mcp_server
# SPIDER_QWEN_MCP_SEARCH_TOOL=web_search
# --- Fetch provider selection: tinyfish | qwen_web_extractor | mock ---
SPIDER_QWEN_FETCH_PROVIDER=tinyfish

# --- Qwen-proposes / deterministic-verifies seams (off by default; the
#     judged-demo profile enables both, mocked when offline) ---
# QWEN_QUERY_REWRITER_ENABLED=1     # CRAG corrective pivot queries
# QWEN_RFQ_DRAFTER_ENABLED=1        # Qwen RFQ body + deterministic fact-check
# QWEN_QUERY_REWRITER_MODEL=qwen-flash
# QWEN_RFQ_DRAFTER_MODEL=qwen3.7-max

# --- State directory for evidence ledgers, memory, traces ---
SPIDER_QWEN_STATE_DIR=.spider_qwen
