# spider-qwen environment configuration
# Copy to .env and fill in. NEVER commit .env.

# --- TinyFish (primary web layer: Search + Fetch) ---
TINYFISH_API_KEY=your_tinyfish_key_here
TINYFISH_SEARCH_BASE_URL=https://api.search.tinyfish.ai
TINYFISH_FETCH_BASE_URL=https://api.fetch.tinyfish.ai
TINYFISH_FETCH_BATCH_SIZE=10
TINYFISH_TIMEOUT_SECONDS=60
TINYFISH_MAX_RETRIES=2
TINYFISH_SEARCH_RPM=30
TINYFISH_FETCH_URLS_PER_MINUTE=150

# --- Qwen / Alibaba Model Studio (WebExtractor fallback + optional MCP search) ---
# Used only by the optional Qwen WebExtractor single-page fallback provider.
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
QWEN_WEB_EXTRACTOR_MODEL=qwen3-max-2026-01-23

# --- Search provider selection: tinyfish | qwen_mcp | mock ---
SPIDER_QWEN_SEARCH_PROVIDER=tinyfish
# --- Fetch provider selection: tinyfish | qwen_web_extractor | mock ---
SPIDER_QWEN_FETCH_PROVIDER=tinyfish

# --- State directory for evidence ledgers, memory, traces ---
SPIDER_QWEN_STATE_DIR=.spider_qwen
